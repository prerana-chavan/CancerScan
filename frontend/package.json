{
  "name": "cancer-scan",
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron ./electron/main.cjs",
    "electron:dev": "vite build && electron ./electron/main.cjs",
    "start": "vite build && electron ./electron/main.cjs",
    "package": "vite build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "framer-motion": "^10.16.5",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "latest",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.1",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^4.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.cancerscan.app",
    "productName": "CancerScan",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
